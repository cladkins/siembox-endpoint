#!/bin/sh
# postinstall - run by the macOS Installer after files are laid down.
# Seeds config from the template, installs osquery + grype if missing, registers
# the launchd service, and launches the menu bar app. Configuration and
# start/stop are then done from the menu bar app — no Terminal needed.
set -e

CONF_DIR="/Library/Application Support/SIEMBox/agent"
CONF="$CONF_DIR/agent.json"
BIN="/usr/local/bin/siembox-agent"
OSQUERY_VERSION="5.23.0"

if [ ! -f "$CONF" ] && [ -f "$CONF_DIR/agent.json.template" ]; then
	cp "$CONF_DIR/agent.json.template" "$CONF"
	chmod 600 "$CONF"
fi

# grype (vulnerability scanner).
if ! command -v grype >/dev/null 2>&1 && [ ! -x /usr/local/bin/grype ]; then
	curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh | sh -s -- -b /usr/local/bin || true
fi

# osquery (host telemetry for detection). Install the official macOS pkg if no
# osqueryi is present in the usual locations.
if ! command -v osqueryi >/dev/null 2>&1 \
	&& [ ! -x /usr/local/bin/osqueryi ] \
	&& [ ! -x /opt/osquery/lib/osquery.app/Contents/MacOS/osqueryi ]; then
	TMP=$(mktemp -d)
	if curl -fsSL -o "$TMP/osquery.pkg" "https://pkg.osquery.io/darwin/osquery-${OSQUERY_VERSION}.pkg"; then
		installer -pkg "$TMP/osquery.pkg" -target / || \
			echo "siembox-agent: WARNING: osquery install failed; detection (check) disabled until installed."
	else
		echo "siembox-agent: WARNING: could not download osquery; detection disabled until installed."
	fi
	rm -rf "$TMP"
fi

# Register the launchd service, then (re)start it so the just-installed binary is
# the one running. This matters on UPGRADE: without the restart the previous
# daemon keeps running the old version until reboot. `restart` loads + kickstarts
# via modern launchctl and works whether or not the service was already running.
# Configuration and scans are driven from the menu bar app — no Terminal needed.
# Full Disk Access is intentionally NOT requested: scans are scoped to
# world-readable software locations and the detection checks don't need it.
"$BIN" -dir "$CONF_DIR" install || true
"$BIN" -dir "$CONF_DIR" restart || true

# (Re)launch the menu bar app for the logged-in user. On upgrade a still-running
# old app keeps the old code, so kill it first and let `open` start the new one.
CONSOLE_UID=$(/usr/bin/stat -f%u /dev/console 2>/dev/null || echo "")
if [ -n "$CONSOLE_UID" ] && [ "$CONSOLE_UID" != "0" ]; then
	/usr/bin/pkill -f "SIEMBox Menu Bar.app" >/dev/null 2>&1 || true
	# Launch with a clean env (-i ... TMPDIR unset): the installer's TMPDIR
	# points at a PKInstallSandbox temp that macOS deletes after install, and a
	# launched app would inherit it and break grype/osquery temp files.
	/bin/launchctl asuser "$CONSOLE_UID" /usr/bin/env -u TMPDIR /usr/bin/open -a "SIEMBox Menu Bar" >/dev/null 2>&1 || true
fi

exit 0
